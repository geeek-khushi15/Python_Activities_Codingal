# Function to remove duplicate values from a list while preserving order
def remove_duplicates(input_list):
    seen = set()
    result = []
    for item in input_list:
        if item not in seen:
            seen.add(item)
            result.append(item)
    return result

# Example usage
original_list = [10, 20, 20, 30, 40, 10, 50, 30]
unique_list = remove_duplicates(original_list)

print(f"Original List: {original_list}")
print(f"List after removing duplicates: {unique_list}")
