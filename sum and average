# Function to calculate the sum and average of elements in a list
def sum_and_average(numbers):
    if not numbers:
        return 0, 0
    
    total_sum = sum(numbers)
    avg = total_sum / len(numbers)
    return total_sum, avg

# Example usage
numbers_list = [10, 20, 30, 40, 50]
total, average = sum_and_average(numbers_list)

print(f"List: {numbers_list}")
print(f"Sum: {total}")
print(f"Average: {average}")
