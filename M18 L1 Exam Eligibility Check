# Exam Eligibility Check

medical_cause = input("Do you have a medical cause? (Y/N): ").strip().upper()

if medical_cause == 'Y':
    print("You are eligible for the exam due to medical cause.")
else:
    attendance = float(input("Enter your attendance percentage: "))
    if attendance >= 75:
        print("You are eligible for the exam.")
    else:
        print("You are NOT eligible for the exam due to low attendance.")
