import math

def perform_operation(a, b, operation):
    if operation == "divide":
        if b != 0:
            return a / b
        else:
            return "Error: Cannot divide by zero"
    elif operation == "sqrt":
        if a >= 0:
            return math.sqrt(a)
        else:
            return "Error: Cannot find square root of a negative number"
    return "Invalid operation"

# Example usage
print(perform_operation(10, 2, "divide"))
print(perform_operation(25, 0, "sqrt"))
