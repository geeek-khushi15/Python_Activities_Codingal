# Function to demonstrate set intersection and related operations
def intersect_sets():
    set1 = {1, 2, 3, 4, 5}
    set2 = {4, 5, 6, 7, 8}
    
    print(f"Set 1: {set1}")
    print(f"Set 2: {set2}")
    
    # Intersection using the intersection() method
    intersection_method = set1.intersection(set2)
    print(f"Intersection (Method): {intersection_method}")
    
    # Intersection using the intersection operator (&)
    intersection_operator = set1 & set2
    print(f"Intersection (Operator &): {intersection_operator}")

# Example usage
intersect_sets()
