# Activity 1: AND-OR operator
# Checking conditions using logical operators

a = 10
b = 12
c = 0

# Using OR operator (returns True if at least one condition is True)
if a > 0 or b > 0:
    print("Either a or b is greater than 0")
else:
    print("Neither a nor b is greater than 0")

# Using AND operator (returns True only if both conditions are True)
if a > 0 and c > 0:
    print("Both a and c are greater than 0")
else:
    print("At least one of the values (a or c) is not greater than 0")
