import random


class FruitQuiz:
    def __init__(self):
        # Dictionary containing fruits and their respective colors
        self.fruits = {
            "apple": "red",
            "orange": "orange",
            "watermelon": "green",
            "banana": "yellow",
            "strawberry": "red",
        }

    def quiz(self):
        print("Welcome to Fruit Quiz!")
        score = 0

        while True:
            # Randomly select a fruit (key) from the dictionary
            fruit, color = random.choice(list(self.fruits.items()))

            # Asking user for the color
            user_answer = input(f"What is the color of {fruit}? ").strip().lower()

            if user_answer == color:
                print("Correct!")
                score += 1
            else:
                print(f"Wrong! The correct answer is {color}.")

            # Option to continue or exit the quiz
            option = int(
                input(
                    "Press 0 to play again, or any other number to quit: "
                )
            )
            if option != 0:
                print(f"\nGame Over! Your final score is: {score}")
                break


# Creating an instance of FruitQuiz and starting the game
fq = FruitQuiz()
fq.quiz()
